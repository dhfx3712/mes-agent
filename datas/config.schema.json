{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "mes-agent 配置",
  "description": "mes-agent 结构化配置，替代 CONFIG.md 中的配置数据",
  "type": "object",
  "required": ["feishu", "bitable", "executor_mapping", "priority_options", "limits", "flow_rules"],
  "properties": {
    "feishu": {
      "type": "object",
      "description": "飞书应用配置",
      "required": ["apps", "chat_id"],
      "properties": {
        "apps": {
          "type": "object",
          "description": "飞书应用列表",
          "required": ["bitable", "messaging"],
          "properties": {
            "bitable": {
              "type": "object",
              "required": ["appId"],
              "properties": {
                "appId": { "type": "string", "description": "Bitable 操作的 app_id" },
                "description": { "type": "string" }
              }
            },
            "messaging": {
              "type": "object",
              "required": ["appId"],
              "properties": {
                "appId": { "type": "string", "description": "消息推送的 app_id" },
                "description": { "type": "string" }
              }
            }
          }
        },
        "chat_id": { "type": "string", "description": "日报推送群 chat_id" }
      }
    },
    "bitable": {
      "type": "object",
      "description": "飞书多维表格配置",
      "required": ["base_app_id", "table_id", "fields"],
      "properties": {
        "base_app_id": { "type": "string" },
        "table_id": { "type": "string" },
        "view_id": { "type": "string" },
        "fields": {
          "type": "object",
          "description": "字段映射",
          "additionalProperties": {
            "type": "object",
            "required": ["id", "type", "desc"],
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string" },
              "desc": { "type": "string" }
            }
          }
        }
      }
    },
    "executor_mapping": {
      "type": "object",
      "description": "执行人姓名 → open_id 映射",
      "additionalProperties": { "type": "string", "pattern": "^ou_" }
    },
    "priority_options": {
      "type": "array",
      "description": "优先级选项",
      "items": {
        "type": "object",
        "required": ["value", "label"],
        "properties": {
          "value": { "type": "string" },
          "label": { "type": "string" }
        }
      }
    },
    "limits": {
      "type": "object",
      "description": "业务限制",
      "required": ["title_max_length", "default_query_days"],
      "properties": {
        "title_max_length": { "type": "integer", "minimum": 1 },
        "default_query_days": { "type": "integer", "minimum": 1 }
      }
    },
    "flow_rules": {
      "type": "object",
      "description": "Flow 路由规则",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "required_slots": { "type": "array", "items": { "type": "string" } },
          "optional_slots": { "type": "array", "items": { "type": "string" } },
          "defaults": { "type": "object" },
          "ctx": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
